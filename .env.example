# =============================================================
# Respectlytics Community Edition — Environment Variables
# =============================================================
# Copy this file to .env and fill in the values.

# REQUIRED: Django secret key (generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=change-me-in-production

# REQUIRED for production: Set to False
DEBUG=True

# REQUIRED for production: Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (auto-configured by docker-compose, override for manual setup)
DATABASE_URL=postgres://respectlytics:changeme@localhost:5432/respectlytics
POSTGRES_PASSWORD=changeme

# Database SSL (set to True for managed PostgreSQL services like AWS RDS, DigitalOcean)
# Leave False for Docker Compose local PostgreSQL
DATABASE_SSL=False

# HTTPS/SSL redirect (set to True when behind an HTTPS reverse proxy like nginx/Caddy)
# Leave False for local Docker Compose or plain HTTP deployments
SECURE_SSL=False

# Port (default 8080)
PORT=8080

# --- Optional ---

# MaxMind GeoIP (free account at https://www.maxmind.com/en/geolite2/signup)
# Enables automatic country detection from IP addresses.
# Without this, country field will be empty (analytics still work).
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# Admin 2FA (requires django-otp setup, see docs/REFERENCE.md)
ADMIN_REQUIRE_OTP=False

# Email (default: prints to console, configure for real email delivery)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=Respectlytics <noreply@example.com>
